[
  {
    "name": "theme_info",
    "theme_name": "Soleil Beauty Shop Custom",
    "theme_version": "1.0.0",
    "theme_author": "Custom Adaptation",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Logo and Favicon",
    "settings": [
      {
        "type": "paragraph",
        "content": "Manage your store name and branding."
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo Image"
      },
      {
        "type": "image_picker",
        "id": "logo_inverse",
        "label": "Inverse Logo (for dark backgrounds)",
        "info": "Use for sections with black backgrounds."
      },
      {
        "type": "range",
        "id": "logo_height",
        "label": "Desktop Logo Height",
        "min": 12,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 36,
        "visible_if": "{{ settings.logo != blank or settings.logo_inverse != blank }}",
        "info": "Adjust for responsive design."
      },
      {
        "type": "range",
        "id": "logo_height_mobile",
        "label": "Mobile Logo Height",
        "min": 12,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 28,
        "visible_if": "{{ settings.logo != blank or settings.logo_inverse != blank }}",
        "info": "Smaller for mobile screens."
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Images",
    "settings": [
      {
        "type": "paragraph",
        "content": "Upload global images that can be used across all pages (e.g., in templates or sections)."
      },
      {
        "type": "image_picker",
        "id": "default_hero_image",
        "label": "Default Hero Image",
        "info": "Use as a fallback hero image on pages without a specific image."
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Mobile Hero Image",
        "info": "Use for mobile-optimized hero images."
      },
      {
        "type": "image_picker",
        "id": "default_background_image",
        "label": "Default Background Image",
        "info": "Use for page backgrounds or overlays."
      },
      {
        "type": "image_picker",
        "id": "default_footer_image",
        "label": "Default Footer Image",
        "info": "Use for footer branding or decorative elements."
      },
      {
        "type": "image_picker",
        "id": "default_banner_image",
        "label": "Default Banner Image",
        "info": "Use for promotional banners across pages."
      }
    ]
  },
