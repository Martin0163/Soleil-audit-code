  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "work_sans_n4",
        "label": "Body Font",
        "info": "Use for general text; League Spartan can be added via CSS if needed."
      },
      {
        "type": "font_picker",
        "id": "type_subheading_font",
        "default": "work_sans_n5",
        "label": "Subheading Font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "anonymous_pro_n4",
        "label": "Heading Font"
      },
      {
        "type": "header",
        "content": "Paragraph"
      },
      {
        "type": "select",
        "id": "type_size_paragraph",
        "label": "Size",
        "options": [
          {"value": "14", "label": "14px"},
          {"value": "16", "label": "16px"},
          {"value": "18", "label": "18px"}
        ],
        "default": "14"
      },
      {
        "type": "select",
        "id": "type_line_height_paragraph",
        "label": "Line Height",
        "options": [
          {"value": "body-normal", "label": "Normal"}
        ],
        "default": "body-normal"
      },
      {
        "type": "header",
        "content": "H1"
      },
      {
        "type": "select",
        "id": "type_size_h1",
        "label": "Size",
        "options": [
          {"value": "32", "label": "32px"},
          {"value": "40", "label": "40px"},
          {"value": "48", "label": "48px"}
        ],
        "default": "48"
      },
      {
        "type": "select",
        "id": "type_line_height_h1",
        "label": "Line Height",
        "options": [
          {"value": "display-normal", "label": "Normal"}
        ],
        "default": "display-normal"
      }
    ]
  },
  {
    "name": "Page Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Page Width",
        "options": [
          {"value": "narrow", "label": "Narrow"},
          {"value": "normal", "label": "Normal"}
        ],
        "default": "narrow"
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "page_transition_enabled",
        "label": "Enable Page Transitions",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "add_to_cart_animation",
        "label": "Add-to-Cart Animation",
        "default": true
      },
      {
        "type": "select",
        "id": "card_hover_effect",
        "label": "Product Card Hover Effect",
        "options": [
          {"value": "lift", "label": "Lift"},
          {"value": "scale", "label": "Scale"}
        ],
        "default": "lift"
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "header",
        "content": "Primary Button"
      },
      {
        "type": "range",
        "id": "primary_button_border_width",
        "min": 0,
        "max": 4,
        "step": 1,
        "unit": "px",
        "label": "Border Width",
        "default": 0
      },
      {
        "type": "range",
        "id": "button_border_radius_primary",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Border Radius",
        "default": 5
      },
      {
        "type": "select",
        "id": "type_font_button_primary",
        "label": "Font",
        "options": [
          {"value": "body", "label": "Body"}
        ],
        "default": "body"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "options": [
          {"value": "page", "label": "Page"},
          {"value": "drawer", "label": "Drawer"}
        ],
        "default": "page"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "Show Cart Note",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_add_discount_code",
        "label": "Show Discount Code",
        "default": true
      }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "quick_add",
        "label": "Enable Quick Add",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_second_image_on_hover",
        "label": "Show Second Image on Hover",
        "default": true
      }
    ]
  }
]