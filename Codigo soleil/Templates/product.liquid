<div class="product-template">

  

  {% comment %} Breadcrumbs {% endcomment %}

  <div class="container">

    <nav class="breadcrumbs" aria-label="Breadcrumb">

      <ol class="breadcrumbs-list">

        <li><a href="{{ routes.root_url }}">Home</a></li>

        {% if collection %}

          <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>

        {% endif %}

        <li aria-current="page">{{ product.title }}</li>

      </ol>

    </nav>

  </div>



  {% comment %} Product Main {% endcomment %}

  <div class="container">

    <div class="product-main">

      

      {% comment %} Product Gallery {% endcomment %}

      <div class="product-gallery">

        <div class="product-gallery-main">

          {% assign featured_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}

          <img
  src="{{ featured_image | image_url: width: 1000 }}"
  srcset="
    {{ featured_image | image_url: width: 600 }} 600w,
    {{ featured_image | image_url: width: 800 }} 800w,
    {{ featured_image | image_url: width: 1000 }} 1000w,
    {{ featured_image | image_url: width: 1200 }} 1200w
  "
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ featured_image.alt | escape | default: product.title }}"
          data-product-main-image
          loading="eager"
          width="1000"
          height="750"
>

        </div>



        {% if product.images.size > 1 %}

          <div class="product-gallery-thumbnails">

            {% for image in product.images %}

          <button

          class="thumbnail{% if forloop.first %} is-active{% endif %}"

          data-thumbnail

          data-image-id="{{ image.id }}"

          data-image-url="{{ image | image_url: width: 1000 }}"

          aria-label="View image {{ forloop.index }}"

        >

        <img
  src="{{ image | image_url: width: 150 }}"

  alt="{{ image.alt | escape }}"

  loading="lazy"

  width="150"

  height="112"
>

              </button>

            {% endfor %}

          </div>

        {% endif %}

      </div>



      {% comment %} Product Info {% endcomment %}

      <div class="product-info">

        

        {% if product.vendor %}

          <p class="product-vendor">

            <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>

          </p>

        {% endif %}



        <h1 class="product-title">{{ product.title }}</h1>



        {% if product.metafields.reviews.rating.value %}

          <div class="product-rating">

            <div class="rating-stars" style="--rating: {{ product.metafields.reviews.rating.value }}">

              <span class="stars-filled">★★★★★</span>

              <span class="stars-empty">★★★★★</span>

            </div>

            <span class="rating-count">({{ product.metafields.reviews.rating_count }} reviews)</span>

          </div>

        {% endif %}



        <div class="product-price">

          {% render 'price', product: product, show_badges: true, show_savings: true %}

        </div>



        {% if product.description != blank %}

          <div class="product-description">

            {{ product.description }}

          </div>

        {% endif %}



        {% form 'product', product, class: 'product-form', data-product-form: '' %}

          

          {% unless product.has_only_default_variant %}

            <div class="product-variants">

              {% for option in product.options_with_values %}

                <div class="variant-option">

                  <label class="variant-label">

                    {{ option.name }}

                  </label>

                  

                  {% if option.name == 'Color' or option.name == 'Colour' %}

                    <div class="variant-swatches">

                      {% for value in option.values %}

                        <input

                          type="radio"

                          name="options[{{ option.name }}]"

                          value="{{ value | escape }}"

                          id="option-{{ option.name }}-{{ forloop.index }}"

                          {% if option.selected_value == value %}checked{% endif %}

                          data-variant-input

                        >

                        <label 

                          for="option-{{ option.name }}-{{ forloop.index }}"

                          class="variant-swatch"

                          style="background-color: {{ value | handleize }};"

                          title="{{ value }}"

                        >

                          <span class="visually-hidden">{{ value }}</span>

                        </label>

                      {% endfor %}

                    </div>

                  {% else %}

                    <select

                      name="options[{{ option.name }}]"

                      class="variant-select"

                      data-variant-input

                    >

                      {% for value in option.values %}

                        <option 

                          value="{{ value | escape }}"

                          {% if option.selected_value == value %}selected{% endif %}

                        >

                          {{ value }}

                        </option>

                      {% endfor %}

                    </select>

                  {% endif %}

                </div>

              {% endfor %}

            </div>

          {% endunless %}



          <div class="product-quantity">

            <label for="quantity" class="quantity-label">Quantity</label>

            <div class="quantity-input">

              <button type="button" class="quantity-btn quantity-minus" aria-label="Decrease quantity">

                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">

                  <path d="M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>

                </svg>

              </button>

              <input

                type="number"

                name="quantity"

                id="quantity"

                value="1"

                min="1"

                class="quantity-value"

              >

              <button type="button" class="quantity-btn quantity-plus" aria-label="Increase quantity">

                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">

                  <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>

                </svg>

              </button>

            </div>

          </div>



          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>



          <div class="product-actions">

            <button

              type="submit"

              name="add"

              class="btn btn-primary btn-lg btn-full"

              {% unless product.available %}disabled{% endunless %}

              data-add-to-cart

            >

              <span class="btn-text">

                {% if product.available %}

                  Add to Cart

                {% else %}

                  Sold Out

                {% endif %}

              </span>

            </button>



            <button type="button" class="btn btn-secondary btn-lg" data-wishlist-toggle>

              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">

                <path d="M10 18.35L8.55 17.03C3.4 12.36 0 9.27 0 5.5C0 2.41 2.42 0 5.5 0C7.24 0 8.91 0.81 10 2.08C11.09 0.81 12.76 0 14.5 0C17.58 0 20 2.41 20 5.5C20 9.27 16.6 12.36 11.45 17.03L10 18.35Z" fill="currentColor"/>

              </svg>

              Add to Wishlist

            </button>

          </div>



        {% endform %}



        {% if product.metafields.custom.features %}

          <div class="product-features">

            <h3 class="features-title">Key Features</h3>

            <ul class="features-list">

              {% assign features = product.metafields.custom.features | split: ',' %}

              {% for feature in features %}

                <li class="feature-item">

                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">

                    <path d="M13.333 4L6 11.333L2.667 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>

                  </svg>

                  {{ feature }}

                </li>

              {% endfor %}

            </ul>

          </div>

        {% endif %}



        <div class="product-meta">

          {% if product.tags.size > 0 %}

            <div class="product-tags">

              <strong>Tags:</strong>

              {% for tag in product.tags %}

                <a href="{{ routes.collections_url }}/all/{{ tag | handle }}" class="tag">{{ tag }}</a>

              {% endfor %}

            </div>

          {% endif %}



          <div class="product-share">

            <strong>Share:</strong>

            <div class="share-buttons">

              <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">

                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">

                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>

                </svg>

              </a>

              <a href="https://twitter.com/share?url={{ shop.url }}{{ product.url }}&text={{ product.title }}" target="_blank" rel="noopener" aria-label="Share on Twitter">

                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">

                  <path d="M19.167 3.333a9.083 9.083 0 01-2.617 1.275 3.733 3.733 0 00-6.55 2.5v.833A8.883 8.883 0 012.5 3.333s-3.333 7.5 4.167 10.834a9.7 9.7 0 01-5.834 1.666c7.5 4.167 16.667 0 16.667-9.583a3.75 3.75 0 00-.067-.692A6.433 6.433 0 0019.167 3.333z"/>

                </svg>

              </a>

              <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 1000 }}&description={{ product.title }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">

                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">

                  <path d="M10 1.667C5.398 1.667 1.667 5.398 1.667 10c0 3.53 2.197 6.546 5.297 7.76-.073-.66-.139-1.671.029-2.39.151-.65.977-4.142.977-4.142s-.249-.5-.249-1.239c0-1.158.672-2.023 1.508-2.023.71 0 1.053.533 1.053 1.173 0 .715-.455 1.783-.69 2.775-.196.829.417 1.506 1.233 1.506 1.482 0 2.62-1.562 2.62-3.817 0-1.994-1.433-3.39-3.481-3.39-2.371 0-3.763 1.778-3.763 3.617 0 .716.276 1.485.621 1.902a.25.25 0 01.058.24l-.232.944c-.037.152-.121.186-.279.112-1.041-.485-1.692-2.006-1.692-3.228 0-2.629 1.91-5.046 5.507-5.046 2.891 0 5.138 2.061 5.138 4.814 0 2.87-1.81 5.185-4.325 5.185-.845 0-1.638-.438-1.91-.957l-.52 1.982c-.188.724-.696 1.632-1.037 2.185.781.242 1.61.372 2.469.372 4.602 0 8.333-3.731 8.333-8.333S14.602 1.667 10 1.667z"/>

                </svg>

              </a>

            </div>

          </div>

        </div>



      </div>



    </div>

  </div>



  {% comment %} Product Recommendations {% endcomment %}

  <div class="container">

    <div class="product-recommendations" data-product-recommendations>

      <h2 class="section-title">You May Also Like</h2>

      <div class="recommendations-grid" data-recommendations-grid></div>

    </div>

  </div>



</div>



<style>

  .product-template {

    padding: var(--space-3xl) 0;

  }



  .breadcrumbs {

    margin-bottom: var(--space-xl);

  }



  .breadcrumbs-list {

    display: flex;

    gap: var(--space-sm);

    list-style: none;

    font-size: var(--font-size-sm);

    color: var(--color-gray-600);

  }



  .breadcrumbs-list li:not(:last-child)::after {

    content: '/';

    margin-left: var(--space-sm);

  }



  .breadcrumbs-list a {

    color: inherit;

    text-decoration: none;

  }



  .breadcrumbs-list a:hover {

    color: var(--color-yellow);

  }



  .product-main {

    display: grid;

    grid-template-columns: 1fr 1fr;

    gap: var(--space-4xl);

    margin-bottom: var(--space-5xl);

  }



  /* Gallery */

  .product-gallery {

    display: flex;

    flex-direction: column;

    gap: var(--space-lg);

  }



  .product-gallery-main {

    aspect-ratio: 1;

    overflow: hidden;

    border-radius: var(--radius-xl);

    background: var(--color-gray-100);

  }



  .product-gallery-main img {

    width: 100%;

    height: 100%;

    object-fit: cover;

  }



  .product-gallery-thumbnails {

    display: grid;

    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));

    gap: var(--space-md);

  }



  .thumbnail {

    aspect-ratio: 1;

    border: 2px solid var(--color-gray-200);

    border-radius: var(--radius-md);

    overflow: hidden;

    cursor: pointer;

    transition: border-color var(--duration-base) var(--ease-out);

    background: none;

    padding: 0;

  }



  .thumbnail:hover,

  .thumbnail.is-active {

    border-color: var(--color-yellow);

  }



  .thumbnail img {

    width: 100%;

    height: 100%;

    object-fit: cover;

  }



  /* Info */

  .product-info {

    display: flex;

    flex-direction: column;

    gap: var(--space-lg);

  }



  .product-vendor {

    font-size: var(--font-size-sm);

    font-weight: var(--font-weight-semibold);

    text-transform: uppercase;

    letter-spacing: 0.05em;

    color: var(--color-gray-600);

  }



  .product-vendor a {

    color: inherit;

    text-decoration: none;

  }



  .product-vendor a:hover {

    color: var(--color-yellow);

  }



  .product-title {

    font-size: var(--font-size-4xl);

    font-weight: var(--font-weight-bold);

    line-height: 1.2;

    margin: 0;

  }



  .product-rating {

    display: flex;

    align-items: center;

    gap: var(--space-sm);

  }



  .rating-stars {

    position: relative;

    display: inline-block;

    font-size: var(--font-size-lg);

    color: var(--color-yellow);

  }



  .stars-filled {

    position: absolute;

    top: 0;

    left: 0;

    overflow: hidden;

    width: calc(var(--rating) * 20%);

  }



  .stars-empty {

    color: var(--color-gray-300);

  }



  .rating-count {

    font-size: var(--font-size-sm);

    color: var(--color-gray-600);

  }



  .product-description {

    font-size: var(--font-size-base);

    line-height: var(--line-height-relaxed);

    color: var(--color-gray-700);

  }



  .product-form {

    display: flex;

    flex-direction: column;

    gap: var(--space-lg);

  }



  .product-variants {

    display: flex;

    flex-direction: column;

    gap: var(--space-md);

  }



  .variant-label {

    display: block;

    font-size: var(--font-size-sm);

    font-weight: var(--font-weight-semibold);

    margin-bottom: var(--space-xs);

    color: var(--color-gray-700);

  }



  .variant-select {

    width: 100%;

    padding: var(--space-sm) var(--space-md);

    border: 1px solid var(--color-gray-300);

    border-radius: var(--radius-md);

    font-size: var(--font-size-base);

    background: var(--color-white);

    cursor: pointer;

  }



  .variant-swatches {

    display: flex;

    gap: var(--space-sm);

    flex-wrap: wrap;

  }



  .variant-swatches input {

    position: absolute;

    opacity: 0;

    pointer-events: none;

  }



  .variant-swatch {

    width: 44px;

    height: 44px;

    border-radius: var(--radius-full);

    border: 2px solid var(--color-gray-300);

    cursor: pointer;

    transition: all var(--duration-base) var(--ease-out);

  }



  .variant-swatches input:checked  .variant-swatch {

    border-color: var(--color-yellow);

    box-shadow: 0 0 0 2px var(--color-yellow);

  }



  .product-quantity {

    display: flex;

    flex-direction: column;

    gap: var(--space-xs);

  }



  .quantity-label {

    font-size: var(--font-size-sm);

    font-weight: var(--font-weight-semibold);

    color: var(--color-gray-700);

  }



  .quantity-input {

    display: flex;

    align-items: center;

    border: 1px solid var(--color-gray-300);

    border-radius: var(--radius-md);

    overflow: hidden;

    width: fit-content;

  }



  .quantity-btn {

    padding: var(--space-md);

    background: var(--color-gray-100);

    border: none;

    cursor: pointer;

    color: var(--color-gray-700);

    transition: all var(--duration-base) var(--ease-out);

  }



  .quantity-btn:hover {

    background: var(--color-yellow);

    color: var(--color-black);

  }



  .quantity-value {

    width: 80px;

    padding: var(--space-md);

    border: none;

    text-align: center;

    font-size: var(--font-size-base);

    font-weight: var(--font-weight-semibold);

  }



  .product-actions {

    display: flex;

    gap: var(--space-md);

  }



  .product-actions .btn {

    flex: 1;

  }



  .product-features {

    padding: var(--space-lg);

    background: var(--color-gray-50);

    border-radius: var(--radius-lg);

  }



  .features-title {

    font-size: var(--font-size-lg);

    font-weight: var(--font-weight-bold);

    margin-bottom: var(--space-md);

  }



  .features-list {

    list-style: none;

    display: flex;

    flex-direction: column;

    gap: var(--space-sm);

  }



  .feature-item {

    display: flex;

    align-items: center;

    gap: var(--space-sm);

    font-size: var(--font-size-sm);

    color: var(--color-gray-700);

  }



  .feature-item svg {

    color: var(--color-yellow);

    flex-shrink: 0;

  }



  .product-meta {

    display: flex;

    flex-direction: column;

    gap: var(--space-md);

    padding-top: var(--space-lg);

    border-top: 1px solid var(--color-gray-200);

    font-size: var(--font-size-sm);

  }



  .product-tags {

    display: flex;

    align-items: center;

    gap: var(--space-sm);

    flex-wrap: wrap;

  }



  .tag {

    padding: var(--space-xs) var(--space-sm);

    background: var(--color-gray-100);

    border-radius: var(--radius-full);

    color: var(--color-gray-700);

    text-decoration: none;

    transition: all var(--duration-base) var(--ease-out);

  }



  .tag:hover {

    background: var(--color-yellow);

    color: var(--color-black);

  }



  .product-share {

    display: flex;

    align-items: center;

    gap: var(--space-sm);

  }



  .share-buttons {

    display: flex;

    gap: var(--space-xs);

  }



  .share-buttons a {

    display: flex;

    align-items: center;

    justify-content: center;

    width: 36px;

    height: 36px;

    border-radius: var(--radius-full);

    background: var(--color-gray-100);

    color: var(--color-gray-700);

    transition: all var(--duration-base) var(--ease-out);

  }



  .share-buttons a:hover {

    background: var(--color-yellow);

    color: var(--color-black);

  }



  .product-recommendations {

    padding: var(--space-4xl) 0;

  }



  .recommendations-grid {

    display: grid;

    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));

    gap: var(--space-xl);

    margin-top: var(--space-xl);

  }



  /* Responsive */

  @media (max-width: 1024px) {

    .product-main {

      grid-template-columns: 1fr;

      gap: var(--space-3xl);

    }

  }



  @media (max-width: 768px) {

    .product-template {

      padding: var(--space-2xl) 0;

    }



    .product-title {

      font-size: var(--font-size-2xl);

    }



    .product-actions {

      flex-direction: column;

    }



    .recommendations-grid {

      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));

      gap: var(--space-lg);

    }

  }

</style>



<script>

  // Product page JavaScript

  document.addEventListener('DOMContentLoaded', function() {

    // Thumbnail gallery

    const thumbnails = document.querySelectorAll('[data-thumbnail]');

    const mainImage = document.querySelector('[data-product-main-image]');

    

    thumbnails.forEach(thumb => {

      thumb.addEventListener('click', () => {

        thumbnails.forEach(t => t.classList.remove('is-active'));

        thumb.classList.add('is-active');

        mainImage.src = thumb.dataset.imageUrl;

      });

    });



    // Quantity controls

    const quantityMinus = document.querySelector('.quantity-minus');

    const quantityPlus = document.querySelector('.quantity-plus');

    const quantityInput = document.querySelector('.quantity-value');

    

    if (quantityMinus && quantityPlus && quantityInput) {

      quantityMinus.addEventListener('click', () => {

        const value = parseInt(quantityInput.value);

        if (value > 1) quantityInput.value = value - 1;

      });

      

      quantityPlus.addEventListener('click', () => {

        const value = parseInt(quantityInput.value);

        quantityInput.value = value  1;

      });

    }



    // Product recommendations

    const recommendationsContainer = document.querySelector('[data-recommendations-grid]');

    if (recommendationsContainer) {

      const productId = {{ product.id }};

      fetch(`/recommendations/products.json?product_id=${productId}&limit=4`)

        .then(response => response.json())

        .then(data => {

          if (data.products && data.products.length > 0) {

            // Render product cards (simplified)

            data.products.forEach(product => {

              const card = document.createElement('div');

              card.innerHTML = `

                <a href="${product.url}">

                  <img src="${product.featured_image}" alt="${product.title}">

                  <h3>${product.title}</h3>

                  <p>${Shopify.formatMoney(product.price)}</p>

                </a>

              `;

              recommendationsContainer.appendChild(card);

            });

          }

        });

    }

  });

</script>