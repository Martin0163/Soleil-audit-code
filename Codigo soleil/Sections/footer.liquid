<footer class="site-footer" role="contentinfo">

  {%- if section.settings.show_newsletter -%}

    <div class="footer-newsletter">

      <div class="container">

        <div class="newsletter-wrapper">

          <div class="newsletter-content">

            <h2 class="newsletter-title">{{ section.settings.newsletter_title | default: 'Stay Connected' }}</h2>

            <p class="newsletter-description">{{ section.settings.newsletter_text | default: 'Subscribe to get special offers, free giveaways, and beauty tips.' }}</p>

          </div>

          

          <div class="newsletter-form-wrapper">

            {% form 'customer', class: 'newsletter-form' %}

              <input type="hidden" name="contact[tags]" value="newsletter">

              <div class="form-group">

                <label for="newsletter-email" class="visually-hidden">{{ 'general.newsletter.email' | t }}</label>

                <input 

                  type="email" 

                  name="contact[email]" 

                  id="newsletter-email" 

                  class="form-input"

                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"

                  required

                  aria-required="true"

                >

                <button type="submit" class="btn btn-primary" aria-label="{{ 'general.newsletter.submit' | t }}">

                  <span>{{ section.settings.newsletter_button | default: 'Subscribe' }}</span>

                  <svg class="icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">

                    <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>

                  </svg>

                </button>

              </div>

              

              {%- if form.posted_successfully? -%}

                <p class="form-success" role="status">{{ 'general.newsletter.success' | t }}</p>

              {%- elsif form.errors -%}

                <p class="form-error" role="alert">{{ form.errors | default_errors }}</p>

              {%- endif -%}

            {% endform %}

          </div>

        </div>

      </div>

    </div>

  {%- endif -%}



  <div class="footer-main">

    <div class="container">

      <div class="footer-grid">

        {%- comment -%} Brand Column {%- endcomment -%}

        <div class="footer-column footer-brand">

          {%- if section.settings.show_logo and section.settings.logo -%}

            <img 

              src="{{ section.settings.logo | image_url: width: 200 }}" 

              alt="{{ shop.name }}"

              class="footer-logo"

              loading="lazy"

              width="150"

              height="auto"

            >

          {%- else -%}

            <h3 class="footer-logo-text">{{ shop.name }}</h3>

          {%- endif -%}

          

          {%- if section.settings.footer_description != blank -%}

            <p class="footer-description">{{ section.settings.footer_description }}</p>

          {%- endif -%}

          

          {%- if section.settings.show_social -%}

            <div class="footer-social">

              <h4 class="footer-social-title">{{ section.settings.social_title | default: 'Follow Us' }}</h4>

              <ul class="social-links" role="list">

                {%- if settings.social_facebook_link != blank -%}

                  <li><a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>

                  </a></li>

                {%- endif -%}

                {%- if settings.social_instagram_link != blank -%}

                  <li><a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>

                  </a></li>

                {%- endif -%}

                {%- if settings.social_twitter_link != blank -%}

                  <li><a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="Twitter">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>

                  </a></li>

                {%- endif -%}

                {%- if settings.social_pinterest_link != blank -%}

                  <li><a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.237 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.182-.78 1.172-4.97 1.172-4.97s-.299-.6-.299-1.486c0-1.39.806-2.428 1.81-2.428.852 0 1.264.64 1.264 1.408 0 .858-.545 2.14-.828 3.33-.236.995.5 1.807 1.48 1.807 1.778 0 3.144-1.874 3.144-4.58 0-2.393-1.72-4.068-4.177-4.068-2.845 0-4.515 2.135-4.515 4.34 0 .859.331 1.781.745 2.281a.3.3 0 01.069.288l-.278 1.133c-.044.183-.145.223-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.965-.525-2.291-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>

                  </a></li>

                {%- endif -%}

                {%- if settings.social_youtube_link != blank -%}

                  <li><a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>

                  </a></li>

                {%- endif -%}

                {%- if settings.social_tiktok_link != blank -%}

                  <li><a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">

                    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/></svg>

                  </a></li>

                {%- endif -%}

              </ul>

            </div>

          {%- endif -%}

        </div>



        {%- comment -%} Navigation Columns {%- endcomment -%}

        {%- for block in section.blocks -%}

          {%- case block.type -%}

            {%- when 'link_list' -%}

              <div class="footer-column" {{ block.shopify_attributes }}>

                {%- if block.settings.title != blank -%}

                  <h4 class="footer-column-title">{{ block.settings.title }}</h4>

                {%- endif -%}

                

                {%- if block.settings.menu != blank -%}

                  <ul class="footer-links" role="list">

                    {%- for link in linklists[block.settings.menu].links -%}

                      <li>

                        <a href="{{ link.url }}" class="footer-link">

                          {{ link.title }}

                        </a>

                      </li>

                    {%- endfor -%}

                  </ul>

                {%- endif -%}

              </div>

              

            {%- when 'text' -%}

              <div class="footer-column" {{ block.shopify_attributes }}>

                {%- if block.settings.title != blank -%}

                  <h4 class="footer-column-title">{{ block.settings.title }}</h4>

                {%- endif -%}

                

                {%- if block.settings.content != blank -%}

                  <div class="footer-text">{{ block.settings.content }}</div>

                {%- endif -%}

              </div>

          {%- endcase -%}

        {%- endfor -%}

      </div>

    </div>

  </div>



  <div class="footer-bottom">

    <div class="container">

      <div class="footer-bottom-content">

        <div class="footer-copyright">

          <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text | default: 'All rights reserved.' }}</p>

        </div>

        

        {%- if section.settings.show_payment_icons -%}

          <div class="footer-payment">

            <span class="visually-hidden">{{ '' }}</span>

            {%- for type in shop.enabled_payment_types -%}

              {{ type | payment_type_svg_tag: class: 'payment-icon' }}

            {%- endfor -%}

          </div>

        {%- endif -%}

      </div>

    </div>

  </div>

</footer>



<style>

  .site-footer {

    background: var(--color-black);

    color: var(--color-white);

    margin-top: auto;

  }



  .footer-newsletter {

    background: linear-gradient(135deg, var(--color-black) 0%, #1a1a1a 100%);

    padding: 4rem 0;

    border-bottom: 1px solid rgba(255, 255, 255, 0.1);

  }



  .newsletter-wrapper {

    display: grid;

    grid-template-columns: 1fr 1fr;

    gap: 3rem;

    align-items: center;

  }



  .newsletter-title {

    font-size: 2rem;

    font-weight: 700;

    margin-bottom: 0.5rem;

    color: var(--color-white);

  }



  .newsletter-description {

    color: rgba(255, 255, 255, 0.7);

    font-size: 1rem;

    line-height: 1.6;

  }



  .newsletter-form {

    width: 100%;

  }



  .newsletter-form .form-group {

    display: flex;

    gap: 0.5rem;

  }



  .newsletter-form .form-input {

    flex: 1;

    padding: 1rem 1.5rem;

    border: 2px solid rgba(255, 255, 255, 0.2);

    background: rgba(255, 255, 255, 0.05);

    color: var(--color-white);

    border-radius: 50px;

    font-size: 1rem;

    transition: all 0.3s ease;

  }



  .newsletter-form .form-input:focus {

    outline: none;

    border-color: var(--color-yellow);

    background: rgba(255, 255, 255, 0.1);

  }



  .newsletter-form .form-input::placeholder {

    color: rgba(255, 255, 255, 0.5);

  }



  .newsletter-form .btn {

    padding: 1rem 2rem;

    white-space: nowrap;

    display: flex;

    align-items: center;

    gap: 0.5rem;

  }



  .footer-main {

    padding: 4rem 0 3rem;

  }



  .footer-grid {

    display: grid;

    grid-template-columns: 2fr repeat(3, 1fr);

    gap: 3rem;

  }



  .footer-brand {

    padding-right: 2rem;

  }



  .footer-logo {

    max-width: 150px;

    height: auto;

    margin-bottom: 1.5rem;

  }



  .footer-logo-text {

    font-size: 1.5rem;

    font-weight: 700;

    margin-bottom: 1.5rem;

    color: var(--color-yellow);

  }



  .footer-description {

    color: rgba(255, 255, 255, 0.7);

    line-height: 1.6;

    margin-bottom: 2rem;

  }



  .footer-social-title {

    font-size: 0.875rem;

    font-weight: 600;

    text-transform: uppercase;

    letter-spacing: 0.05em;

    margin-bottom: 1rem;

    color: var(--color-white);

  }



  .social-links {

    display: flex;

    gap: 1rem;

    list-style: none;

    padding: 0;

    margin: 0;

  }



  .social-links a {

    display: flex;

    align-items: center;

    justify-content: center;

    width: 40px;

    height: 40px;

    border-radius: 50%;

    background: rgba(255, 255, 255, 0.1);

    color: var(--color-white);

    transition: all 0.3s ease;

  }



  .social-links a:hover {

    background: var(--color-yellow);

    color: var(--color-black);

    transform: translateY(-3px);

  }



  .footer-column-title {

    font-size: 1rem;

    font-weight: 600;

    text-transform: uppercase;

    letter-spacing: 0.05em;

    margin-bottom: 1.5rem;

    color: var(--color-white);

  }



  .footer-links {

    list-style: none;

    padding: 0;

    margin: 0;

  }



  .footer-links li {

    margin-bottom: 0.75rem;

  }



  .footer-link {

    color: rgba(255, 255, 255, 0.7);

    text-decoration: none;

    transition: all 0.3s ease;

    display: inline-block;

  }



  .footer-link:hover {

    color: var(--color-yellow);

    transform: translateX(5px);

  }



  .footer-text {

    color: rgba(255, 255, 255, 0.7);

    line-height: 1.6;

  }



  .footer-bottom {

    border-top: 1px solid rgba(255, 255, 255, 0.1);

    padding: 2rem 0;

  }



  .footer-bottom-content {

    display: flex;

    justify-content: space-between;

    align-items: center;

  }



  .footer-copyright p {

    color: rgba(255, 255, 255, 0.6);

    font-size: 0.875rem;

    margin: 0;

  }



  .footer-payment {

    display: flex;

    gap: 0.5rem;

    align-items: center;

  }



  .payment-icon {

    height: 24px;

    width: auto;

    opacity: 0.7;

    transition: opacity 0.3s ease;

  }



  .payment-icon:hover {

    opacity: 1;

  }



  /* Responsive Design */

  @media (max-width: 1024px) {

    .footer-grid {

      grid-template-columns: repeat(2, 1fr);

    }



    .footer-brand {

      grid-column: 1 / -1;

      padding-right: 0;

      margin-bottom: 2rem;

    }

  }



  @media (max-width: 768px) {

    .newsletter-wrapper {

      grid-template-columns: 1fr;

      text-align: center;

    }



    .newsletter-form .form-group {

      flex-direction: column;

    }



    .newsletter-form .btn {

      width: 100%;

      justify-content: center;

    }



    .footer-grid {

      grid-template-columns: 1fr;

      gap: 2rem;

    }



    .footer-bottom-content {

      flex-direction: column;

      gap: 1.5rem;

      text-align: center;

    }



    .social-links {

      justify-content: center;

    }

  }

</style>



{% schema %}

{

  "name": "Footer",

  "settings": [

    {

      "type": "header",

      "content": "Newsletter"

    },

    {

      "type": "checkbox",

      "id": "show_newsletter",

      "label": "Show newsletter signup",

      "default": true

    },

    {

      "type": "text",

      "id": "newsletter_title",

      "label": "Newsletter title",

      "default": "Stay Connected"

    },

    {

      "type": "textarea",

      "id": "newsletter_text",

      "label": "Newsletter description",

      "default": "Subscribe to get special offers, free giveaways, and beauty tips."

    },

    {

      "type": "text",

      "id": "newsletter_placeholder",

      "label": "Email placeholder",

      "default": "Enter your email"

    },

    {

      "type": "text",

      "id": "newsletter_button",

      "label": "Button text",

      "default": "Subscribe"

    },

    {

      "type": "header",

      "content": "Brand"

    },

    {

      "type": "checkbox",

      "id": "show_logo",

      "label": "Show logo",

      "default": true

    },

    {

      "type": "image_picker",

      "id": "logo",

      "label": "Logo image"

    },

    {

      "type": "textarea",

      "id": "footer_description",

      "label": "Description",

      "default": "Your trusted source for premium beauty products and skincare essentials."

    },

    {

      "type": "header",

      "content": "Social Media"

    },

    {

      "type": "checkbox",

      "id": "show_social",

      "label": "Show social links",

      "default": true

    },

    {

      "type": "text",

      "id": "social_title",

      "label": "Social title",

      "default": "Follow Us"

    },

    {

      "type": "header",

      "content": "Bottom Bar"

    },

    {

      "type": "text",

      "id": "copyright_text",

      "label": "Copyright text",

      "default": "All rights reserved."

    },

    {

      "type": "checkbox",

      "id": "show_payment_icons",

      "label": "Show payment icons",

      "default": true

    }

  ],

  "blocks": [

    {

      "type": "link_list",

      "name": "Menu",

      "settings": [

        {

          "type": "text",

          "id": "title",

          "label": "Heading",

          "default": "Quick Links"

        },

        {

          "type": "link_list",

          "id": "menu",

          "label": "Menu",

          "default": "footer"

        }

      ]

    },

    {

      "type": "text",

      "name": "Text",

      "settings": [

        {

          "type": "text",

          "id": "title",

          "label": "Heading",

          "default": "Contact"

        },

        {

          "type": "richtext",

          "id": "content",

          "label": "Content",

          "default": "<p>Email: info@example.com<br>Phone: (123) 456-7890</p>"

        }

      ]

    }

  ],

  "default": {

    "blocks": [

      {

        "type": "link_list",

        "settings": {

          "title": "Shop",

          "menu": "footer"

        }

      },

      {

        "type": "link_list",

        "settings": {

          "title": "Information",

          "menu": "footer"

        }

      },

      {

        "type": "text",

        "settings": {

          "title": "Contact",

          "content": "<p>Email: info@example.com<br>Phone: (123) 456-7890</p>"

        }

      }

    ]

  }

}

{% endschema %}