{% comment %}
  Footer Section - Refactored
  
  Features:
  - Multi-column layout with link lists
  - Newsletter signup with validation
  - Social media links with SVG icons
  - Payment method icons
  - Trust badges
  - Back to top button
  - Schema-driven customization
  - Fully responsive
  - No inline styles
  
  Usage: {% section 'footer' %}
{% endcomment %}

<footer class="footer" role="contentinfo">
  <div class="container">
    
    {%- comment -%} Main Footer Content {%- endcomment -%}
    <div class="footer__main">
      <div class="footer__grid">
        
        {%- comment -%} Brand Column {%- endcomment -%}
        <div class="footer__column footer__column--brand">
          {% if section.settings.footer_logo %}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 200 }}"
              alt="{{ shop.name }}"
              class="footer__logo"
              width="150"
              height="auto"
              loading="lazy"
            />
          {% else %}
            <h2 class="footer__brand-name">{{ shop.name }}</h2>
          {% endif %}
          
          {% if section.settings.footer_description != blank %}
            <p class="footer__description">
              {{ section.settings.footer_description }}
            </p>
          {% endif %}
          
          {%- comment -%} Social Links {%- endcomment -%}
          {% if section.settings.show_social %}
            <div class="footer__social">
              <h3 class="footer__social-title">Follow Us</h3>
              <ul class="social-links" role="list">
                {% if settings.social_facebook_link != blank %}
                  <li>
                    <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">
                      <svg class="icon icon--facebook" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </a>
                  </li>
                {% endif %}
                
                {% if settings.social_instagram_link != blank %}
                  <li>
                    <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
                      <svg class="icon icon--instagram" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  </li>
                {% endif %}
                
                {% if settings.social_twitter_link != blank %}
                  <li>
                    <a href="{{ settings.social_twitter_link }}" class="social-link" aria-label="Twitter" target="_blank" rel="noopener">
                      <svg class="icon icon--twitter" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                      </svg>
                    </a>
                  </li>
                {% endif %}
                
                {% if settings.social_pinterest_link != blank %}
                  <li>
                    <a href="{{ settings.social_pinterest_link }}" class="social-link" aria-label="Pinterest" target="_blank" rel="noopener">
                      <svg class="icon icon--pinterest" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
                      </svg>
                    </a>
                  </li>
                {% endif %}
                
                {% if settings.social_tiktok_link != blank %}
                  <li>
                    <a href="{{ settings.social_tiktok_link }}" class="social-link" aria-label="TikTok" target="_blank" rel="noopener">
                      <svg class="icon icon--tiktok" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                      </svg>
                    </a>
                  </li>
                {% endif %}
              </ul>
            </div>
          {% endif %}
        </div>
        
        {%- comment -%} Link Lists {%- endcomment -%}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'link_list' %}
              <div class="footer__column" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h3 class="footer__heading">{{ block.settings.heading }}</h3>
                {% endif %}
                
                {% if block.settings.menu != blank %}
                  <ul class="footer__menu" role="list">
                    {% for link in linklists[block.settings.menu].links %}
                      <li class="footer__menu-item">
                        <a href="{{ link.url }}" class="footer__link">
                          {{ link.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
        
        {%- comment -%} Newsletter Column {%- endcomment -%}
        {% if section.settings.show_newsletter %}
          <div class="footer__column footer__column--newsletter">
            <h3 class="footer__heading">{{ section.settings.newsletter_heading | default: 'Stay Connected' }}</h3>
            <p class="footer__newsletter-text">
              {{ section.settings.newsletter_text | default: 'Subscribe to get special offers, free giveaways, and exclusive deals.' }}
            </p>
            
            {% form 'customer', class: 'footer__newsletter-form' %}
              {% if form.posted_successfully? %}
                <div class="form-message form-message--success" role="status">
                  <svg class="icon icon--check" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{{ section.settings.newsletter_success_message | default: 'Thanks for subscribing!' }}</span>
                </div>
              {% endif %}
              
              {% if form.errors %}
                <div class="form-message form-message--error" role="alert">
                  {{ form.errors | default_errors }}
                </div>
              {% endif %}
              
              <input type="hidden" name="contact[tags]" value="newsletter">
              
              <div class="footer__newsletter-input-wrapper">
                <label for="footer-email" class="visually-hidden">Email address</label>
                <input
                  type="email"
                  name="contact[email]"
                  id="footer-email"
                  class="footer__newsletter-input"
                  placeholder="Enter your email"
                  required
                  aria-required="true"
                  autocomplete="email"
                />
                <button type="submit" class="footer__newsletter-btn" aria-label="Subscribe">
                  <svg class="icon icon--arrow-right" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M4.167 10h11.666M10 4.167L15.833 10 10 15.833" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            {% endform %}
          </div>
        {% endif %}
      </div>
    </div>
    
    {%- comment -%} Trust Badges {%- endcomment -%}
    {% if section.settings.show_trust_badges %}
      <div class="footer__trust">
        <div class="trust-badges">
          <div class="trust-badge">
            <svg class="icon icon--shield" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Secure Checkout</span>
          </div>
          <div class="trust-badge">
            <svg class="icon icon--truck" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="2"/>
              <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>Free Shipping Over $50</span>
          </div>
          <div class="trust-badge">
            <svg class="icon icon--return" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>30-Day Returns</span>
          </div>
        </div>
      </div>
    {% endif %}
    
    {%- comment -%} Payment Icons {%- endcomment -%}
    {% if section.settings.show_payment_icons %}
      <div class="footer__payment">
        <h3 class="footer__payment-title">We Accept</h3>
        <div class="payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      </div>
    {% endif %}
    
    {%- comment -%} Bottom Bar {%- endcomment -%}
    <div class="footer__bottom">
      <div class="footer__bottom-content">
        <p class="footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        </p>
        
        {% if section.settings.show_policies %}
          <ul class="footer__policies" role="list">
            {% if shop.privacy_policy %}
              <li>
                <a href="{{ shop.privacy_policy.url }}" class="footer__policy-link">
                  Privacy Policy
                </a>
              </li>
            {% endif %}
            {% if shop.terms_of_service %}
              <li>
                <a href="{{ shop.terms_of_service.url }}" class="footer__policy-link">
                  Terms of Service
                </a>
              </li>
            {% endif %}
            {% if shop.refund_policy %}
              <li>
                <a href="{{ shop.refund_policy.url }}" class="footer__policy-link">
                  Refund Policy
                </a>
              </li>
            {% endif %}
          </ul>
        {% endif %}
      </div>
    </div>
  </div>
  
  {%- comment -%} Back to Top Button {%- endcomment -%}
  {% if section.settings.show_back_to_top %}
    <button
      type="button"
      class="back-to-top"
      data-back-to-top
      aria-label="Back to top"
      hidden
    >
      <svg class="icon icon--arrow-up" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {% endif %}
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand Section"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Description",
      "default": "Your one-stop shop for premium beauty products."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter Signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Stay Connected"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Subscribe to get special offers, free giveaways, and exclusive deals."
    },
    {
      "type": "text",
      "id": "newsletter_success_message",
      "label": "Success Message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "header",
      "content": "Trust & Payment"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show Trust Badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Show Policy Links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show Back to Top Button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Information",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
