{% comment %}
Products Grid Section
- Displays products from a chosen collection with a limit.
- Customizable section: choose collection, max products, and grid columns.
- Future: Add quick view buttons, infinite scrolling, or sorting options.
{% endcomment %}

<section class="products" id="products" aria-label="Product Listing">
  <h2>{{ section.settings.title }}</h2>
  <div class="product-grid" role="list" style="display: grid; grid-template-columns: repeat({{ section.settings.columns | default: 3 }}, 1fr); gap: 2rem;">
    {% assign collection_obj = collections[section.settings.collection] %}
    {% if collection_obj and collection_obj.products != empty %}
      {% for product in collection_obj.products limit: section.settings.limit %}
        {% render 'product_card', product: product %}
      {% endfor %}
    {% else %}
      <p>No hay productos para mostrar.</p>
    {% endif %}
  </div>
</section>

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
  }
  /* Future: Add hover effects or loading states */
</style>

{% schema %}
{
  "name": "Products Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Productos Destacados" },
    { "type": "collection", "id": "collection", "label": "Product Collection" },
    { "type": "number", "id": "limit", "label": "Max products to show", "default": 6 },
    { "type": "number", "id": "columns", "label": "Grid Columns", "default": 3 }  // Fixed: Removed invalid 'min' and 'max' attributes
  ],
  "presets": [{ "name": "Productos Destacados" }]
}
{% endschema %}