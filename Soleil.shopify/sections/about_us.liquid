{% comment %}
About Us Section

This section is designed for your About Us page.
You can add name, mission, team photos, history, videos,
or any custom content by editing the section settings or
adding blocks in the theme editor.

To use this section, create a page and assign a template that
includes this section, or include it in your main page templates.

Future improvements: Add team member blocks, testimonials, or contact forms.
{% endcomment %}

<section class="about-us" style="max-width:1200px; margin: 3rem auto; padding: 0 2rem; color: var(--black);" aria-labelledby="about-title">
  <!-- Title -->
  <h1 id="about-title" style="font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">
    {{ section.settings.title }}
  </h1>

  <!-- Subtitle -->
  <p style="font-size: 1.2rem; margin-bottom: 2rem;">
    {{ section.settings.subtitle }}
  </p>

  <!-- Content blocks -->
  {% for block in section.blocks %}
    <div class="about-block" style="margin-bottom: 2rem;" role="region" aria-label="Content block {{ forloop.index }}">
      {% if block.type == 'text' %}
        <h2 style="font-size: 1.8rem; font-weight: 600; margin-bottom: 0.5rem;">
          {{ block.settings.block_title }}
        </h2>
        <p>{{ block.settings.block_text }}</p>

      {% elsif block.type == 'image' %}
        <img 
          src="{{ block.settings.image | image_url: width: 1200, height: 400, crop: 'center' }}" 
          width="1200" 
          height="400"  
          alt="{{ block.settings.image_alt }}" 
          loading="lazy" 
          style="width: 100%; max-width: 600px; border-radius: 10px; aspect-ratio: 3/1;" 
        />

      {% elsif block.type == 'video' %}
        <video controls style="width:100%; max-width:600px; border-radius:10px;" aria-label="Video content">
          <source src="{{ block.settings.video_url }}" type="video/mp4" />
          Tu navegador no soporta este video.
        </video>
      {% endif %}
    </div>
  {% endfor %}
</section>

<style>
  /* Responsive design for about-us section */
  @media (max-width: 768px) {
    .about-us {
      padding: 0 1rem;
    }
    .about-us h1 {
      font-size: 2.5rem;
    }
    .about-us p {
      font-size: 1.1rem;
    }
  }
  /* Hover effects for blocks */
  .about-block:hover {
    transform: translateY(-2px);
    transition: transform 0.3s ease;
  }
  /* Future: Add more styles for team blocks or animations */
</style>

{% schema %}
{
  "name": "About Us Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Bienvenido a Soleil Beauty Shop"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Descubre nuestra historia y compromiso con la belleza."
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "block_title",
          "label": "Block Title"
        },
        {
          "type": "textarea",
          "id": "block_text",
          "label": "Block Text"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image Alt Text"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video Block",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (MP4)"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}