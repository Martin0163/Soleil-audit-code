{% comment %}
Dreams Section
- Displays a single image with optional title.
- Future improvements: Add multiple images, overlays, or call-to-action buttons.
{% endcomment %}

<section class="dreams-section" style="max-width: 1200px; margin: 3rem auto; padding: 0 2rem; text-align: center;" aria-labelledby="dreams-title">
  {% if section.settings.title %}
    <h2 id="dreams-title" style="font-size: 2.5rem; font-weight: 700; margin-bottom: 2rem;">
      {{ section.settings.title }}
    </h2>
  {% endif %}
  <img 
    src="{{ section.settings.dreams_image | image_url: width: 800, height: 300, crop: 'center' }}" 
    width="800" 
    height="300"
    alt="{{ section.settings.dreams_alt }}"
    loading="lazy"
    style="width: 100%; max-width: 800px; border-radius: 10px; aspect-ratio: 8/3;"
  />
</section>

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    .dreams-section img {
      max-width: 100%;
    }
  }
  /* Future: Add hover effects or animations */
</style>

{% schema %}
{
  "name": "Dreams Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title (Optional)",
      "default": "Dreams"  // Fixed: Changed from "" to "Dreams" to avoid blank default error
    },
    {
      "type": "image_picker",
      "id": "dreams_image",
      "label": "Dreams Image"
    },
    {
      "type": "text",
      "id": "dreams_alt",
      "label": "Image Alt Text",
      "default": "Dreams image"
    }
  ],
  "presets": [
    {
      "name": "Dreams"
    }
  ]
}
{% endschema %}