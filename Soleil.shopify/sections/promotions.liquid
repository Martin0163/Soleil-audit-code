{% comment %}
Promotions Section
- Displays a promotional message with title, text, and link.
- Customizable via schema settings.
- Future: Add images, countdown timers, or multiple promotions.
{% endcomment %}

<section class="promotion" style="background-color: var(--yellow); color: var(--black); padding: 3rem 2rem; text-align: center; margin: 3rem 0;" aria-labelledby="promotion-title">
  <h2 id="promotion-title" style="font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">{{ section.settings.title }}</h2>
  <p style="font-size: 1.2rem;">{{ section.settings.description }}</p>
  <a href="{{ section.settings.link }}" class="promotion-button">{{ section.settings.button_text }}</a>
</section>

<style>
  .promotion-button:hover {
    background-color: var(--yellow);
    color: var(--black);
  }
  /* Responsive design */
  @media (max-width: 768px) {
    .promotion {
      padding: 2rem 1rem;
    }
    .promotion h2 {
      font-size: 1.8rem;
    }
    .promotion p {
      font-size: 1rem;
    }
  }
  /* Future: Add animations or background images */
</style>

{% schema %}
{
  "name": "Promotions Section",
  "settings": [
    { "type": "text", "id": "title", "label": "Promotion Title", "default": "¡Oferta Especial!" },
    { "type": "textarea", "id": "description", "label": "Promotion Description", "default": "Envío gratis en compras mayores a $1000 MXN." },
    { "type": "url", "id": "link", "label": "Promotion Link", "default": "/collections/all" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Ver productos" }
  ],
  "presets": [{ "name": "Promotions Section" }]
}
{% endschema %}