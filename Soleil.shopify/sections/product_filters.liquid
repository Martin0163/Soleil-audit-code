{% comment %}
Product Filters Section
- Unified filters for brand, skin type, price, special filters, and sorting.
- Auto-submits on change for instant filtering.
- Future improvements: Add AJAX for no-page-reload, more filter types, or saved filters.
{% endcomment %}

<div class="filters" role="region" aria-label="Filtros de productos">
  <form id="filter-form" method="get" action="{{ collection.url }}" aria-live="polite">

    <!-- Brand Filter -->
    <div class="filter-group">
      <label for="filter-vendor">Marca</label>
      <select name="vendor" id="filter-vendor" onchange="this.form.submit()" aria-label="Filter by brand">
        <option value="">Todas</option>
        {% assign vendors_list = '' %}
        {% for product in collection.products limit: 100 %}  <!-- Limit for performance -->
          {% unless vendors_list contains product.vendor %}
            {% if vendors_list == '' %}
              {% assign vendors_list = product.vendor %}
            {% else %}
              {% assign vendors_list = vendors_list | append: ',' | append: product.vendor %}
            {% endif %}
          {% endunless %}
        {% endfor %}
        {% assign vendors = vendors_list | split: ',' | uniq | sort %}
        {% for vendor in vendors %}
          <option value="{{ vendor | strip }}" {% if collection.current_vendor == vendor %} selected {% endif %}>
            {{ vendor | strip }}
          </option>
        {% endfor %}
      </select>
    </div>

    <!-- Skin Type Filter -->
    <div class="filter-group">
      <label for="filter-skin-type">Tipo de piel</label>
      <select name="constraint" id="filter-skin-type" onchange="this.form.submit()" aria-label="Filter by skin type">
        <option value="">Todas</option>
        {% assign skin_types = "combination skin,dry skin,oily skin,normal skin,acne-prone skin" | split: "," %}
        {% for skin_type in skin_types %}
          {% assign skin_type_trimmed = skin_type | strip %}
          {% assign selected = false %}
          {% for tag in current_tags %}
            {% if tag == skin_type_trimmed %}
              {% assign selected = true %}
            {% endif %}
          {% endfor %}
          <option value="{{ skin_type_trimmed | url_encode }}" {% if selected %} selected {% endif %}>
            {{ skin_type_trimmed | capitalize }}
          </option>
        {% endfor %}
      </select>
    </div>

    <!-- Price Range Filter -->
    <div class="filter-group">
      <label for="filter-price">Precio máximo</label>
      <input type="range" id="filter-price" name="max_price" min="0" max="{{ collection.products | map: 'price' | max | divided_by: 100 | ceil }}" step="10"
             value="{{ request.params.max_price | default: 2000 }}"
             oninput="this.nextElementSibling.value = this.value"
             onchange="this.form.submit()" aria-label="Filter by maximum price" />
      <output>{{ request.params.max_price | default: 2000 }}</output>
    </div>

    <!-- Special Filters: Best Sellers & New Arrivals -->
    <div class="filter-group">
      <label for="filter-special">Filtros especiales</label>
      <select id="filter-special" name="filter.special" onchange="this.form.submit()" aria-label="Special filters">
        <option value="">Seleccione</option>
        <option value="best-selling" {% if request.params.filter.special == 'best-selling' %}selected{% endif %}>Más vendidos</option>
        <option value="new-arrivals" {% if request.params.filter.special == 'new-arrivals' %}selected{% endif %}>Nuevos productos</option>
      </select>
    </div>

    <!-- Sort By -->
    <div class="filter-group">
      <label for="filter-sort">Ordenar por</label>
      <select id="filter-sort" name="sort_by" onchange="this.form.submit()" aria-label="Sort products">
        <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Por defecto</option>
        <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Precio: menor a mayor</option>
        <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Precio: mayor a menor</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Nuevos primero</option>
        <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Más vendidos</option>
      </select>
    </div>

  </form>
</div>

<style>
  .filters {
    background: #fff;
    padding: 1rem;
    border-radius: 10px;
    border: 1px solid #eee;
    max-width: 300px;
  }
  .filter-group {
    margin-bottom: 1.5rem;
  }
  label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  select, input[type=range] {
    width: 100%;
    padding: 0.5rem;
    border-radius: 5px;
    border: 1px solid #ccc;
  }
  output {
    display: block;
    text-align: right;
    margin-top: 0.3rem;
    font-weight: 600;
  }
  /* Responsive design */
  @media (max-width: 768px) {
    .filters {
      max-width: 100%;
    }
  }
  /* Future: Add collapsible groups or filter reset button */
</style>