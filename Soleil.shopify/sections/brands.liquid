{% comment %}
Brands Section
- Dynamically creates a grid of unique product vendors (brands).
- Each brand links to its vendor collection.
- Future improvements: add brand logos, descriptions, or featured collections.
- Ensure your products have vendor assigned in Shopify Admin.
{% endcomment %}

<section class="brands-section" style="max-width: 1200px; margin: 0 auto; padding: 2rem;" aria-labelledby="brands-title">
  <h1 id="brands-title" style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1.5rem; text-align: center;">
    Nuestras Marcas
  </h1>

  {% assign vendors_string = '' %}
  {% for product in collections.all.products limit: 100 %}  <!-- Limit for performance -->
    {% unless vendors_string contains product.vendor %}
      {% if vendors_string == '' %}
        {% assign vendors_string = product.vendor %}
      {% else %}
        {% assign vendors_string = vendors_string | append: ',' | append: product.vendor %}
      {% endif %}
    {% endunless %}
  {% endfor %}
  {% assign vendor_list = vendors_string | split: ',' | uniq | sort %}

  {% if vendor_list.size > 0 %}
    <div class="brands-grid" style="display: grid; grid-gap: 2rem; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));" role="list">
      {% for vendor in vendor_list %}
        <a href="/collections/vendors?q={{ vendor | url_encode }}" 
           class="brand-button" 
           style="display: block; background: var(--white); padding: 1rem; border-radius: 10px; text-align: center; font-weight: 600; border: 2px solid var(--yellow); color: var(--black); text-decoration: none;"
           aria-label="Ver productos de {{ vendor }}">
          {{ vendor }}
        </a>
      {% endfor %}
    </div>
  {% else %}
    <p style="text-align: center; font-style: italic;">No hay marcas para mostrar.</p>
  {% endif %}
</section>

<style>
  /* Responsive adjustments */
  @media (max-width: 600px) {
    .brands-grid {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    }
  }
  .brand-button:hover {
    background-color: var(--yellow);
    color: var(--black);
    border-color: var(--yellow);
    transform: scale(1.05);
    transition: all 0.3s ease;
  }
  /* Future: Add styles for brand logos or tooltips */
</style>