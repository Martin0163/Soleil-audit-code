{% comment %}
Hero Section
- Yellow full-width banner with main heading, subtitle, and call-to-action button.
- Settings defined in the schema allow editing content from Shopify admin.
- Future improvements: Add background image, video, or multiple CTAs.
{% endcomment %}

<section class="hero" style="background-color: var(--yellow); padding: 120px 0 80px; text-align: center; color: var(--black); font-weight: 700;" aria-labelledby="hero-title">
  <div>
    <h1 id="hero-title" style="font-size: 3rem; margin-bottom: 1rem;">
      {{ section.settings.hero_title }}
    </h1>
    <p style="font-size: 1.2rem; margin-bottom: 2rem;">
      {{ section.settings.hero_subtitle }}
    </p>
    <a href="{{ section.settings.cta_url }}" class="cta-button" aria-label="{{ section.settings.cta_text }}">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 1rem;
    }
    .hero h1 {
      font-size: 2.5rem;
    }
    .hero p {
      font-size: 1.1rem;
    }
  }
  /* Hover effects */
  .cta-button:hover {
    transform: scale(1.05);
    transition: transform 0.3s ease;
  }
  /* Future: Add background image or gradient styles */
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { 
      "type": "text", 
      "id": "hero_title", 
      "label": "Hero Title", 
      "default": "Bienvenido a Soleil Beauty Shop" 
    },
    { 
      "type": "text", 
      "id": "hero_subtitle", 
      "label": "Hero Subtitle", 
      "default": "Descubre nuestros productos de belleza" 
    },
    { 
      "type": "url", 
      "id": "cta_url", 
      "label": "CTA Button URL", 
      "default": "/collections/all" 
    },
    { 
      "type": "text", 
      "id": "cta_text", 
      "label": "CTA Button Text", 
      "default": "Comprar Ahora" 
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}