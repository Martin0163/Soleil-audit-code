{% comment %}
Mini Cart Section
- Drawer overlay showing cart contents with live updates.
- Includes item list, quantity update, remove button, and checkout link.
- Future improvements: Add animations, persistence, or integration with mini-cart modal.
{% endcomment %}

<div id="mini-cart" class="mini-cart" aria-hidden="true" role="dialog" aria-label="Shopping cart">
  <button id="mini-cart-close" class="close-button" aria-label="Cerrar carrito">×</button>
  <h2>Tu Carrito</h2>
  <div id="mini-cart-items" class="mini-cart-items" role="list"></div>
  <p class="mini-cart-total"><strong>Total:</strong> <span id="mini-cart-total-price"></span></p>
  <a href="{{ routes.cart_url }}" class="button checkout-button">Ir al carrito</a>
</div>

<style>
  /* Mini cart styling */
  .mini-cart {
    position: fixed;
    top: 0; right: 0;
    width: 350px;
    height: 100vh;
    background: #fff;
    box-shadow: -3px 0 10px rgba(0,0,0,0.2);
    padding: 1rem;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 9999;
    display: flex;
    flex-direction: column;
  }
  .mini-cart.open {
    transform: translateX(0);
  }
  .mini-cart-items {
    overflow-y: auto;
    flex-grow: 1;
  }
  .mini-cart-item {
    display: flex;
    margin-bottom: 1rem;
    gap: 0.75rem;
  }
  .mini-cart-item img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
  }
  .mini-cart-item-info h3 {
    font-size: 1rem;
    margin: 0 0 0.3rem 0;
  }
  .mini-cart-item-info p {
    margin: 0;
    font-size: 0.9rem;
  }
  .quantity-controls {
    margin-top: 0.5rem;
  }
  .quantity-controls input {
    width: 50px;
    text-align: center;
  }
  .close-button {
    background: transparent;
    border: none;
    font-size: 2rem;
    align-self: flex-end;
    cursor: pointer;
  }
  .button.checkout-button {
    margin-top: 1rem;
    background: var(--yellow);
    color: var(--black);
    padding: 0.8rem 1.5rem;
    text-align: center;
    border-radius: 5px;
    font-weight: 600;
    display: block;
  }
  /* Responsive design */
  @media (max-width: 768px) {
    .mini-cart {
      width: 100%;
    }
  }
  /* Future: Add hover effects or loading animations */
</style>

<!-- JS moved to theme.js for better performance -->