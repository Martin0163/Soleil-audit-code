/*=====================================================
  Soleil Beauty Shop - Enhanced Main CSS
  Professional animations, transitions, and UX details.
=====================================================*/

@import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;600;700&display=swap');

:root {
  --black: #000000;
  --white: #FFFFFF;
  --yellow: #FFD700;
  --shadow: rgba(0, 0, 0, 0.1);
  --gradient: linear-gradient(135deg, var(--yellow), #FFA500);
}

/* Resets and base styling */
*, *::before, *::after {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
  font-family: 'League Spartan', sans-serif;
  line-height: 1.6;
  color: var(--white);
  background-color: var(--black);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  animation: fadeIn 1s ease-in-out;
}

/* Global fonts and basics */
a { text-decoration: none; color: inherit; }
ul { list-style: none; padding: 0; margin: 0; }

/* Header Styles */
header {
  position: fixed;
  top: 0;
  width: 100%;
  background: var(--black);
  color: var(--black);
  padding: 1rem 2rem;
  box-shadow: 0 4px 20px var(--shadow);
  border-bottom: 1px solid #eee;
  z-index: 1000;
  transition: transform 0.2s ease, opacity 0.2s ease;
  will-change: transform;
}

/* Header hidden state */
header.header--hidden {
  transform: translateY(-100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

/* Navigation */
nav {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo img {
  max-width: 200px;
  height: auto;
  border-radius: 5px;
  color: var(--yellow);
  transition: transform 0.3s ease;
}

.logo img:hover {
  transform: scale(1.05);
}

/* Nav Links */
.nav-links {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.nav-links > li {
  position: relative;
}

.nav-links li a {
  font-weight: 400;
  font-size: 1rem;
  color: var(--black);
  position: relative;
  padding: 0.5rem 0;
  transition: color 0.3s ease, transform 0.3s ease;
  display: block;
}

.nav-links li a:hover {
  color: var(--yellow);
  transform: translateY(-2px);
}

.nav-links li a::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient);
  transition: width 0.3s ease;
}

.nav-links li a:hover::after {
  width: 100%;
}

/* Dropdown menus styling */
.dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  background: var(--white);
  min-width: 250px;
  box-shadow: 0 8px 30px var(--shadow);
  border: 1px solid #eee;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
  transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
  padding: 1rem 0;
  z-index: 1001;
  animation: slideUp 0.3s ease;
}

.nav-links li:hover > .dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

/* Desktop Menu Buttons Section */
.desktop-menu-buttons {
  margin-left: 1rem;
  display: flex;
  gap: 1rem;
}

.desktop-menu-btn {
  background-color: var(--yellow);
  color: var(--black);
  padding: 0.6rem 1.2rem;
  border-radius: 5px;
  font-weight: 600;
  text-decoration: none;
  transition: background-color 0.3s ease, color 0.3s ease;
  cursor: pointer;
}

.desktop-menu-btn:hover {
  background-color: var(--black);
  color: var(--yellow);
}

/* Hide desktop buttons on mobile devices */
@media (max-width: 768px) {
  .desktop-menu-buttons {
    display: none;
  }
}

/* Responsive Mobile Navigation */
@media (max-width: 768px) {
  .hamburger {
    display: flex;
  }
  .nav-links {
    position: fixed;
    top: 70px;
    left: -100%;
    width: 100%;
    height: calc(100vh - 70px);
    background: var(--white);
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    padding-top: 2rem;
    transition: left 0.3s ease;
    box-shadow: 2px 0 10px rgba(0,0,0,0.1);
    z-index: 999;
  }
  .nav-links.active {
    left: 0;
  }
  .nav-links li a {
    font-size: 1.2rem;
    padding: 1rem 0;
  }
  .logo img {
    max-width: 150px;
  }
}

/* Keyframe Animations */
@keyframes fadeIn {
  0% { opacity: 0; transform: translateY(20px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  0% { opacity: 0; transform: translateY(50px); }
  100% { opacity: 1; transform: translateY(0); }
}