{% comment %}
Button Snippet
- Renders a customizable button with label, type, class, and ARIA label.
- Supports generic or specific use cases (e.g., quick view).
- Future improvements: Add variants (primary, secondary), icons, or loading states.
{% endcomment %}

<button type="{{ type | default: 'button' }}" 
        class="{{ class | default: 'button' }}" 
        aria-label="{{ aria_label | default: label }}" 
        {% if onclick %}onclick="{{ onclick }}"{% endif %}>
  {{ label }}
</button>

<style>
  .button {
    background-color: var(--yellow);
    color: var(--black);
    border: none;
    border-radius: 5px;
    padding: 0.8rem 1.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  .button:hover {
    background-color: var(--black);
    color: var(--yellow);
  }
  .quick-view-btn {
    background-color: var(--black);
    color: var(--white);
    border: none;
    border-radius: 5px;
    padding: 0.5rem 1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background-color 0.3s ease;
    display: block;
    width: 100%;
  }
  .quick-view-btn:hover {
    background-color: var(--yellow);
    color: var(--black);
  }
  /* Future: Add disabled state or size variants */
</style>