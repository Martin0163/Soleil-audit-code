{% comment %}
Price Snippet
- Shows the product price with sale support and money formatting.
- Handles compare-at prices with strikethrough.
- Future improvements: Add tax info, currency selectors, or discount badges.
{% endcomment %}

{% if product.compare_at_price > product.price %}
  <span class="price-original" style="text-decoration: line-through; color: #999;" aria-label="Precio original">
    {{ product.compare_at_price | money }}
  </span>
  <span class="price-sale" style="color: var(--yellow); font-weight: 700; margin-left: 0.5rem;" aria-label="Precio de oferta">
    {{ product.price | money }}
  </span>
{% else %}
  <span class="price" style="color: var(--yellow); font-weight: 700;" aria-label="Precio">
    {{ product.price | money }}
  </span>
{% endif %}

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    .price, .price-sale, .price-original {
      font-size: 0.9rem;
    }
  }
  /* Future: Add animations or color variations */
</style>