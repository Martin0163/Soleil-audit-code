{% comment %}
Product Card Snippet
- Displays product image(s), title, price, and add-to-cart form.
- Includes hover effects for secondary images and lazy loading.
- Fully accessible with ARIA labels and keyboard navigation.
- Future improvements: Add variant selectors, wishlist buttons, or stock indicators.
{% endcomment %}

<div class="product-card" role="listitem" tabindex="0">
  <a href="{{ product.url }}" aria-label="Ver producto {{ product.title }}">
    <div class="product-image-container" style="position: relative; overflow: hidden;">
      <img src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
           alt="{{ product.title }}"
           loading="lazy"
           width="400" height="400"
           class="primary-image" />
      {% if product.images.size > 1 %}
        <img src="{{ product.images[1] | image_url: width: 400, height: 400, crop: 'center' }}"
             alt="{{ product.title }} vista alternativa"
             loading="lazy"
             width="400" height="400"
             class="secondary-image"
             style="position: absolute; top: 0; left: 0; opacity: 0; transition: opacity 0.3s ease;" />
      {% endif %}
    </div>
    <h3 class="product-title" style="margin: 1rem 0 0.5rem;">{{ product.title }}</h3>
  </a>

  <div class="price-wrap">
    {% render 'price', product: product %}
  </div>

  <form method="post" action="/cart/add" class="add-to-cart-form" aria-label="Añadir {{ product.title }} al carrito" style="margin-top: 0.5rem;">
    <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
    <button type="submit" class="add-to-cart-button" {% if product.available == false %}disabled{% endif %}>
      {% if product.available %}Añadir al Carrito{% else %}Agotado{% endif %}
    </button>
  </form>
</div>

<style>
  .product-card:hover .secondary-image {
    opacity: 1 !important;
  }
  .product-card:hover .primary-image {
    transform: scale(1.05);
    transition: transform 0.3s ease;
  }
  .add-to-cart-button {
    background-color: var(--yellow);
    color: var(--black);
    border: none;
    border-radius: 5px;
    padding: 0.8rem 1.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    width: 100%;
  }
  .add-to-cart-button:hover:not(:disabled) {
    background-color: var(--black);
    color: var(--yellow);
  }
  .add-to-cart-button:disabled {
    background-color: #ccc;
    cursor: not-allowed;
  }
  /* Responsive design */
  @media (max-width: 768px) {
    .product-card {
      max-width: 100%;
    }
    .product-image-container img {
      width: 100%;
      height: auto;
    }
  }
  /* Future: Add focus styles for keyboard navigation */
</style>