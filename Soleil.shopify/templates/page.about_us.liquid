{% comment %}
About Us Page Template
- Displays the about_us section with header and footer.
- Future improvements: Add breadcrumbs, related pages, or custom layouts.
{% endcomment %}

{% section 'header' %}

<main style="margin-top: 70px;" role="main" aria-labelledby="page-title">
  <h1 id="page-title" class="visually-hidden">{{ page.title }}</h1>
  {% section 'about_us' %}
</main>

{% section 'footer' %}

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  /* Future: Add page-specific styles or backgrounds */
</style>