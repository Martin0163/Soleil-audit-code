{% comment %}
Collection Template
- Displays filters sidebar and product grid for collections.
- Ensure only one filter section to avoid duplication.
- Future improvements: Add breadcrumbs, sorting options, or infinite scroll.
{% endcomment %}

{% section 'header' %}

<main style="margin-top:70px;" role="main" class="collection-layout" aria-labelledby="collection-title">
  <h1 id="collection-title" class="visually-hidden">{{ collection.title }}</h1>
  {% section 'product_filters' %}    <!-- Filters sidebar -->
  {% section 'products' %}           <!-- Product grid -->
</main>

{% section 'footer' %}

<style>
  /* Responsive design */
  @media (max-width: 768px) {
    .collection-layout {
      display: block;
    }
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  /* Future: Add grid adjustments or sidebar toggles */
</style>