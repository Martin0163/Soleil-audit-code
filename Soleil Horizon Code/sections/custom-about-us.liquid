<section class="about-section" data-section-id="{{ section.id }}">

  {% if section.settings.show_hero %}
  <div class="about-hero">
    <div class="about-hero-content">
      <h1 class="about-hero-title animate-fade-in-up">{{ section.settings.hero_title }}</h1>
      <p class="about-hero-subtitle animate-fade-in-up" style="animation-delay: 0.2s;">
        {{ section.settings.hero_subtitle }}
      </p>
    </div>
    {% if section.settings.hero_image %}
      <div class="about-hero-image animate-fade-in" style="animation-delay: 0.4s;">
        <img 
          src="{{ section.settings.hero_image | image_url: width: 1200 }}" 
          alt="{{ section.settings.hero_title | escape }}"
          width="1200"
          height="800"
          loading="lazy"
        >
      </div>
    {% endif %}
  </div>
  {% endif %}

  <div class="container">
    {% comment %} Our Story Section {% endcomment %}
    {% if section.settings.show_story %}
    <div class="about-story">
      <div class="about-story-grid">
        <div class="about-story-content animate-on-scroll">
          <span class="section-label">{{ section.settings.story_label }}</span>
          <h2 class="section-title">{{ section.settings.story_title }}</h2>
          <div class="about-story-text">
            {{ section.settings.story_content }}
          </div>
          {% if section.settings.story_cta_text %}
            <a href="{{ section.settings.story_cta_link }}" class="btn btn-primary">
              {{ section.settings.story_cta_text }}
            </a>
          {% endif %}
        </div>
        {% if section.settings.story_image %}
        <div class="about-story-image animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="image-reveal">
            <img 
              src="{{ section.settings.story_image | image_url: width: 1200 }}" 
              alt="{{ section.settings.story_title | escape }}"
              width="1200"
              height="800"
              loading="lazy"
            >
          </div>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% comment %} Timeline Section {% endcomment %}
    {% if section.settings.show_timeline %}
    <div class="about-timeline">
      <h2 class="section-title text-center">{{ section.settings.timeline_title }}</h2>
      <div class="timeline">
        {% for block in section.blocks %}
          {% if block.type == 'timeline_item' %}
          <div class="timeline-item animate-on-scroll" {{ block.shopify_attributes }}>
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <span class="timeline-year">{{ block.settings.year }}</span>
              <h3 class="timeline-title">{{ block.settings.title }}</h3>
              <p class="timeline-description">{{ block.settings.description }}</p>
            </div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% comment %} Values Section {% endcomment %}
    {% if section.settings.show_values %}
    <div class="about-values">
      <h2 class="section-title text-center">{{ section.settings.values_title }}</h2>
      <div class="values-grid">
        {% for block in section.blocks %}
          {% if block.type == 'value' %}
          <div class="value-card animate-on-scroll" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <div class="value-icon">
                {{ block.settings.icon }}
              </div>
            {% endif %}
            <h3 class="value-title">{{ block.settings.title }}</h3>
            <p class="value-description">{{ block.settings.description }}</p>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% comment %} Team Section {% endcomment %}
    {% if section.settings.show_team %}
    <div class="about-team">
      <h2 class="section-title text-center">{{ section.settings.team_title }}</h2>
      <p class="section-subtitle text-center">{{ section.settings.team_subtitle }}</p>
      <div class="team-grid">
        {% for block in section.blocks %}
          {% if block.type == 'team_member' %}
          <div class="team-member animate-on-scroll" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
            <div class="team-member-image">
              <img 
                src="{{ block.settings.image | image_url: width: 800 }}" 
                alt="{{ block.settings.name | escape }}"
                width="800"
                height="800"
                loading="lazy"
              >
              <div class="team-member-overlay">
                <div class="team-member-social">
                  {% if block.settings.instagram %}
                    <a href="{{ block.settings.instagram }}" target="_blank" rel="noopener" aria-label="{{ block.settings.name }} Instagram">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                      </svg>
                    </a>
                  {% endif %}
                  {% if block.settings.linkedin %}
                    <a href="{{ block.settings.linkedin }}" target="_blank" rel="noopener" aria-label="{{ block.settings.name }} LinkedIn">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                        <rect x="2" y="9" width="4" height="12"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
            {% endif %}
            <div class="team-member-info">
              <h3 class="team-member-name">{{ block.settings.name }}</h3>
              <p class="team-member-role">{{ block.settings.role }}</p>
              <p class="team-member-bio">{{ block.settings.bio }}</p>
            </div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% comment %} Video Section {% endcomment %}
    {% if section.settings.show_video and section.settings.video_url %}
    <div class="about-video">
      <h2 class="section-title text-center">{{ section.settings.video_title }}</h2>
      <div class="video-container animate-on-scroll">
        <div class="video-wrapper">
          {% if section.settings.video_url contains 'youtube.com' or section.settings.video_url contains 'youtu.be' %}
            <iframe 
              src="{{ section.settings.video_url }}" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
              loading="lazy"
              title="{{ section.settings.video_title | escape }}"
            ></iframe>
          {% elsif section.settings.video_url contains 'vimeo.com' %}
            <iframe 
              src="{{ section.settings.video_url }}" 
              frameborder="0" 
              allow="autoplay; fullscreen; picture-in-picture" 
              allowfullscreen
              loading="lazy"
              title="{{ section.settings.video_title | escape }}"
            ></iframe>
          {% endif %}
        </div>
      </div>
    </div>
    {% endif %}

    {% comment %} Testimonials Section {% endcomment %}
    {% if section.settings.show_testimonials %}
    <div class="about-testimonials">
      <h2 class="section-title text-center">{{ section.settings.testimonials_title }}</h2>
      <div class="testimonials-slider" data-testimonials-slider>
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-stars">
              {% for i in (1..5) %}
                <svg class="star-icon" width="20" height="20" viewBox="0 0 24 24" fill="var(--color-yellow)">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {% endfor %}
            </div>
            <p class="testimonial-text">"{{ block.settings.text }}"</p>
            <div class="testimonial-author">
              {% if block.settings.author_image %}
                <img 
                  src="{{ block.settings.author_image | image_url: width: 80, height: 80, crop: 'center' }}" 
                  alt="{{ block.settings.author_name | escape }}"
                  width="80"
                  height="80"
                  class="testimonial-author-image"
                  loading="lazy"
                >
              {% endif %}
              <div>
                <p class="testimonial-author-name">{{ block.settings.author_name }}</p>
                <p class="testimonial-author-title">{{ block.settings.author_title }}</p>
              </div>
            </div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% comment %} CTA Section {% endcomment %}
    {% if section.settings.show_cta %}
    <div class="about-cta">
      <div class="about-cta-content animate-on-scroll">
        <h2 class="about-cta-title">{{ section.settings.cta_title }}</h2>
        <p class="about-cta-text">{{ section.settings.cta_text }}</p>
        <div class="about-cta-buttons">
          {% if section.settings.cta_primary_text %}
            <a href="{{ section.settings.cta_primary_link }}" class="btn btn-primary">
              {{ section.settings.cta_primary_text }}
            </a>
          {% endif %}
          {% if section.settings.cta_secondary_text %}
            <a href="{{ section.settings.cta_secondary_link }}" class="btn btn-outline">
              {{ section.settings.cta_secondary_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
    {% endif %}

  </div>
</section>

<style>
.about-section {
  padding: 80px 0;
}

.about-hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120px 20px;
  background: linear-gradient(135deg, var(--color-black) 0%, var(--color-gray-900) 100%);
  color: var(--color-white);
  overflow: hidden;
}

.about-hero-content {
  position: relative;
  z-index: 2;
  max-width: 800px;
}

.about-hero-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  margin-bottom: 20px;
  color: var(--color-white);
}

.about-hero-subtitle {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  color: var(--color-gray-300);
  line-height: 1.6;
}

.about-story-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 60px;
  align-items: center;
  margin: 80px 0;
}

.about-story-text {
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--color-gray-700);
  margin: 30px 0;
}

.image-reveal {
  position: relative;
  overflow: hidden;
  border-radius: 12px;
}

.image-reveal img {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.6s ease;
}

.image-reveal:hover img {
  transform: scale(1.05);
}

.timeline {
  position: relative;
  max-width: 800px;
  margin: 60px auto;
  padding-left: 40px;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-yellow);
}

.timeline-item {
  position: relative;
  margin-bottom: 40px;
}

.timeline-marker {
  position: absolute;
  left: -44px;
  top: 0;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--color-yellow);
  border: 3px solid var(--color-white);
  box-shadow: 0 0 0 3px var(--color-yellow-light);
}

.timeline-year {
  display: inline-block;
  padding: 4px 12px;
  background: var(--color-yellow);
  color: var(--color-black);
  font-weight: 700;
  border-radius: 20px;
  font-size: 0.9rem;
  margin-bottom: 10px;
}

.timeline-title {
  font-size: 1.5rem;
  font-weight: 600;
  margin: 10px 0;
}

.values-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 40px;
  margin-top: 60px;
}

.value-card {
  text-align: center;
  padding: 40px 30px;
  border-radius: 12px;
  background: var(--color-white);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.value-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
}

.value-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-yellow-light);
  border-radius: 50%;
  color: var(--color-yellow);
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 40px;
  margin-top: 60px;
}

.team-member {
  text-align: center;
}

.team-member-image {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 20px;
}

.team-member-image img {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.3s ease;
}

.team-member-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.team-member:hover .team-member-overlay {
  opacity: 1;
}

.team-member:hover img {
  transform: scale(1.1);
}

.team-member-social {
  display: flex;
  gap: 15px;
}

.team-member-social a {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-yellow);
  color: var(--color-black);
  border-radius: 50%;
  transition: transform 0.3s ease;
}

.team-member-social a:hover {
  transform: scale(1.1);
}

.team-member-name {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 5px;
}

.team-member-role {
  color: var(--color-yellow);
  font-weight: 500;
  margin-bottom: 10px;
}

.video-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  overflow: hidden;
  border-radius: 12px;
}

.video-wrapper iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.testimonials-slider {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-top: 60px;
}

.testimonial-card {
  padding: 40px;
  background: var(--color-white);
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.testimonial-stars {
  display: flex;
  gap: 5px;
  margin-bottom: 20px;
}

.testimonial-text {
  font-size: 1.1rem;
  line-height: 1.6;
  font-style: italic;
  margin-bottom: 20px;
  color: var(--color-gray-700);
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 15px;
}

.testimonial-author-image {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  object-fit: cover;
}

.about-cta {
  text-align: center;
  padding: 80px 20px;
  background: linear-gradient(135deg, var(--color-yellow-light) 0%, var(--color-yellow) 100%);
  border-radius: 20px;
  margin-top: 80px;
}

.about-cta-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  margin-bottom: 20px;
}

.about-cta-buttons {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 30px;
}

@media (max-width: 768px) {
  .about-story-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  
  .timeline {
    padding-left: 30px;
  }
}
</style>

<script>
  // Enhanced About Section JavaScript
  document.addEventListener('DOMContentLoaded', function() {
    try {
      // Animate elements on scroll
      const animatedElements = document.querySelectorAll('.animate-on-scroll');
      
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.classList.add('is-visible');
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        animatedElements.forEach(el => observer.observe(el));
      } else {
        // Fallback for browsers without IntersectionObserver
        animatedElements.forEach(el => el.classList.add('is-visible'));
      }

      // Enhanced video loading
      const videoIframes = document.querySelectorAll('.video-wrapper iframe');
      videoIframes.forEach(iframe => {
        iframe.addEventListener('load', function() {
          this.style.opacity = '1';
        });
        iframe.addEventListener('error', function() {
          console.error('Failed to load video:', this.src);
          this.parentElement.innerHTML = '<p>Video temporarily unavailable</p>';
        });
      });

    } catch (error) {
      console.error('About section initialization error:', error);
    }
  });
</script>

