<section class="brands-section" data-section-id="{{ section.id }}">

  <div class="container">

    

    {% if section.settings.show_header %}

    <div class="section-header text-center">

      {% if section.settings.subtitle %}

        <span class="section-label">{{ section.settings.subtitle }}</span>

      {% endif %}

      <h2 class="section-title">{{ section.settings.title | default: 'Our Brands' }}</h2>

      {% if section.settings.description %}

        <p class="section-description">{{ section.settings.description }}</p>

      {% endif %}

    </div>

    {% endif %}



    {% if section.blocks.size > 0 %}

      <div class="brands-grid" data-brands-grid>

        {% for block in section.blocks %}

          {% if block.type == 'brand' %}

            <div class="brand-item animate-on-scroll" {{ block.shopify_attributes }}>

              {% render 'brand', 

                brand_name: block.settings.brand_name,

                brand_logo: block.settings.brand_logo,

                brand_url: block.settings.brand_url,

                brand_description: block.settings.brand_description

              %}

            </div>

          {% endif %}

        {% endfor %}

      </div>

    {% else %}

      <div class="brands-empty">

        <p>No brands to display. Add brands in the theme editor.</p>

      </div>

    {% endif %}



    {% if section.settings.show_cta %}

      <div class="brands-cta text-center">

        <a href="{{ section.settings.cta_link }}" class="btn btn-primary btn-lg">

          {{ section.settings.cta_text | default: 'View All Brands' }}

        </a>

      </div>

    {% endif %}



  </div>

</section>



<style>

  .brands-section {

    padding: var(--space-4xl) 0;

    background: var(--color-white);

  }



  .section-header {

    margin-bottom: var(--space-3xl);

  }



  .section-label {

    display: inline-block;

    font-size: var(--font-size-sm);

    font-weight: var(--font-weight-semibold);

    text-transform: uppercase;

    letter-spacing: 0.1em;

    color: var(--color-yellow);

    margin-bottom: var(--space-sm);

  }



  .section-title {

    font-size: var(--font-size-4xl);

    font-weight: var(--font-weight-bold);

    color: var(--color-black);

    margin-bottom: var(--space-md);

  }



  .section-description {

    font-size: var(--font-size-lg);

    color: var(--color-gray-600);

    max-width: 600px;

    margin: 0 auto;

  }



  .brands-grid {

    display: grid;

    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));

    gap: var(--space-xl);

    margin-bottom: var(--space-3xl);

  }



  .brand-item {

    opacity: 0;

    transform: translateY(20px);

    transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);

  }



  .brand-item.is-visible {

    opacity: 1;

    transform: translateY(0);

  }



  .brands-empty {

    text-align: center;

    padding: var(--space-4xl) 0;

    color: var(--color-gray-500);

  }



  .brands-cta {

    margin-top: var(--space-3xl);

  }



  @media (max-width: 768px) {

    .brands-section {

      padding: var(--space-3xl) 0;

    }



    .section-title {

      font-size: var(--font-size-3xl);

    }



    .brands-grid {

      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));

      gap: var(--space-lg);

    }

  }

</style>



<script>

  // Animate brands on scroll

  document.addEventListener('DOMContentLoaded', function() {

    const brandItems = document.querySelectorAll('.brand-item');

    

    const observer = new IntersectionObserver((entries) => {

      entries.forEach((entry, index) => {

        if (entry.isIntersecting) {

          setTimeout(() => {

            entry.target.classList.add('is-visible');

          }, index * 100);

          observer.unobserve(entry.target);

        }

      });

    }, { threshold: 0.1 });



    brandItems.forEach(item => observer.observe(item));

  });

</script>



{% schema %}

{

  "name": "Brands",

  "settings": [

    {

      "type": "checkbox",

      "id": "show_header",

      "label": "Show section header",

      "default": true

    },

    {

      "type": "text",

      "id": "subtitle",

      "label": "Subtitle",

      "default": "Premium Beauty"

    },

    {

      "type": "text",

      "id": "title",

      "label": "Title",

      "default": "Our Brands"

    },

    {

      "type": "textarea",

      "id": "description",

      "label": "Description",

      "default": "Discover our curated selection of premium beauty brands"

    },

    {

      "type": "checkbox",

      "id": "show_cta",

      "label": "Show call to action button",

      "default": true

    },

    {

      "type": "text",

      "id": "cta_text",

      "label": "Button text",

      "default": "View All Brands"

    },

    {

      "type": "url",

      "id": "cta_link",

      "label": "Button link"

    }

  ],

  "blocks": [

    {

      "type": "brand",

      "name": "Brand",

      "settings": [

        {

          "type": "text",

          "id": "brand_name",

          "label": "Brand name",

          "default": "Brand Name"

        },

        {

          "type": "image_picker",

          "id": "brand_logo",

          "label": "Brand logo"

        },

        {

          "type": "url",

          "id": "brand_url",

          "label": "Brand URL"

        },

        {

          "type": "textarea",

          "id": "brand_description",

          "label": "Brand description"

        }

      ]

    }

  ],

  "presets": [

    {

      "name": "Brands",

      "category": "Custom"

    }

  ]

}

{% endschema %}